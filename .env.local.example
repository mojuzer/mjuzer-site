# ──────────────────────────────────────────────────────────────────────────
#  Copy this file to .env.local for local dev, and set the same keys in
#  Vercel → Project → Settings → Environment Variables for production.
#
#  Everything here is OPTIONAL. If you leave a value blank, the site still
#  builds and runs — it just falls back gracefully (e.g. the contact form
#  switches to a mailto: link until you add a Formspree endpoint).
#
#  You can also hardcode these directly in lib/content.ts instead of using
#  env vars — whichever you prefer. Env vars win if both are set.
# ──────────────────────────────────────────────────────────────────────────

# Formspree form endpoint — create a form at https://formspree.io and paste
# the endpoint here, e.g. https://formspree.io/f/abcdwxyz
NEXT_PUBLIC_FORMSPREE_ENDPOINT=

# Cal.com (or Calendly) booking link for the discovery call,
# e.g. https://cal.com/mjuzer/discovery  or  https://calendly.com/you/30min
NEXT_PUBLIC_CAL_LINK=

# Analytics — pick ONE (or neither):
#   • Vercel Analytics: no key needed. It auto-activates when deployed on
#     Vercel and you enable Analytics in the dashboard. Nothing to set here.
#   • Plausible: set your domain to enable the script (see app/layout.tsx).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
